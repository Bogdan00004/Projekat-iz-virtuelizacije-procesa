<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<add key="path" value="Files"/>
		<add key="HI_max_threshold" value="40"/>
		<add key="SH_threshold" value="2"/>
	</appSettings>

	<system.serviceModel>
		<services>
			<service name="Server.WeatherService">
				<host>
					<baseAddresses>
						<add baseAddress="net.tcp://localhost:4000"/>
					</baseAddresses>
				</host>
				<endpoint
				  address="WeatherService"
				  binding="netTcpBinding"
				  bindingConfiguration="WeatherBinding"
				  contract="Common.IWeatherService"/>
			</service>
		</services>

		<bindings>
			<netTcpBinding>
				<binding name="WeatherBinding"
						 maxReceivedMessageSize="10485760"
						 receiveTimeout="00:10:00"
						 sendTimeout="00:10:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"
						 transferMode="Buffered">
				</binding>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
</configuration>