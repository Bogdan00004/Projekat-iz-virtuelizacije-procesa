<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<appSettings>
		<add key="csvPath" value="Data\cleaned_weather.csv"/>
	</appSettings>

	<system.serviceModel>
		<client>
			<endpoint
			  name="WeatherService"
			  address="net.tcp://localhost:4000/WeatherService"
			  binding="netTcpBinding"
			  bindingConfiguration="WeatherBinding"
			  contract="Common.IWeatherService"/>
		</client>

		<bindings>
			<netTcpBinding>
				<binding name="WeatherBinding"
						 maxReceivedMessageSize="10485760"
						 receiveTimeout="00:10:00"
						 sendTimeout="00:10:00"
						 openTimeout="00:01:00"
						 closeTimeout="00:01:00"
						 transferMode="Buffered">
				</binding>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
</configuration>